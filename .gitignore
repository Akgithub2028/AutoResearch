cat > .gitignore << 'EOF'
# ==============================
# Python
# ==============================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# ==============================
# Virtual Environments
# ==============================
venv/
.venv/
env/
ENV/
.virtualenv/

# ==============================
# Environment Variables
# ==============================
.env
.env.*
!.env.example

# ==============================
# IDE
# ==============================
.vscode/
.idea/
*.swp

# ==============================
# Jupyter
# ==============================
.ipynb_checkpoints/

# ==============================
# Logs
# ==============================
*.log
logs/

# ==============================
# Testing
# ==============================
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ==============================
# OS Files
# ==============================
.DS_Store
Thumbs.db

# ==============================
# LangSmith / Local Databases
# ==============================
*.db
*.sqlite
*.sqlite3

# ==============================
# Cache
# ==============================
.cache/
EOF
